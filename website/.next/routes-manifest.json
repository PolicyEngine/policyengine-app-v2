{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/",
      "destination": "/us",
      "statusCode": 307,
      "regex": "^(?!/_next)/(?:/)?$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/[countryId]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[countryId]/claude-plugin",
      "regex": "^/([^/]+?)/claude\\-plugin(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/claude\\-plugin(?:/)?$"
    },
    {
      "page": "/[countryId]/donate",
      "regex": "^/([^/]+?)/donate(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/donate(?:/)?$"
    },
    {
      "page": "/[countryId]/privacy",
      "regex": "^/([^/]+?)/privacy(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/privacy(?:/)?$"
    },
    {
      "page": "/[countryId]/research",
      "regex": "^/([^/]+?)/research(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/research(?:/)?$"
    },
    {
      "page": "/[countryId]/supporters",
      "regex": "^/([^/]+?)/supporters(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/supporters(?:/)?$"
    },
    {
      "page": "/[countryId]/team",
      "regex": "^/([^/]+?)/team(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/team(?:/)?$"
    },
    {
      "page": "/[countryId]/terms",
      "regex": "^/([^/]+?)/terms(?:/)?$",
      "routeKeys": {
        "nxtPcountryId": "nxtPcountryId"
      },
      "namedRegex": "^/(?<nxtPcountryId>[^/]+?)/terms(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}