{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "images": {
    "sizes": [128, 256, 384, 512, 640, 750, 828, 1080, 1200, 1920],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 86400
  },
  "installCommand": "cd .. && bun install --frozen-lockfile",
  "buildCommand": "cd .. && bun run design-system:build && cd app && bun run build:calculator",
  "outputDirectory": "../app/dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/calculator.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
